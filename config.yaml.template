# =============================================
# JusticePlutus 配置文件模板
# =============================================
# 使用说明：
# 1. 复制此文件为 config.yaml
# 2. 填入您的API密钥和配置

datasources:
  tushare_token: ""  # Tushare API Token（可选）
  joinquant_username: ""  # JoinQuant 用户名（可选）
  joinquant_password: ""  # JoinQuant 密码（可选）
  mairui_token: ""  # 迈瑞 API Token（可选）

screener:
  price_min: 3  # 最低价格
  price_max: 70  # 最高价格
  min_listed_days: 730  # 最小上市天数（2年）
  weekly_ma: 25  # 周均线
  vol_ma_short: 5  # 短期成交量均线
  vol_ma_long: 60  # 长期成交量均线
  vol_deviation_min: -0.03  # 成交量偏差最小值
  vol_deviation_max: 0.07  # 成交量偏差最大值
  min_daily_amount: 300000000  # 最低日成交额（3亿）
  spot_prefilter_amount: 200000000  # 预筛选成交额（2亿）
  weekly_mode: "realtime"  # 周K模式：realtime 或 completed

request:
  max_workers: 8  # 最大工作线程数
  delay_min: 0.2  # 最小延迟（秒）
  delay_max: 0.5  # 最大延迟（秒）
  max_retries: 3  # 最大重试次数
  retry_backoff: 2  # 重试退避系数

wecom:
  webhook_url: ""  # 企业微信 Webhook URL（可选）

plugins:
  ai_analysis:
    enabled: true  # 是否启用 AI 分析
  llm_analysis:
    enabled: true  # 是否启用 LLM 分析
  stock_list_analysis:
    enabled: true  # 是否启用股票列表分析
  technical_analysis:
    enabled: true  # 是否启用技术指标分析
  fundamental_analysis:
    enabled: true  # 是否启用基本面分析
